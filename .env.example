# Vault Graph Environment Variables
# Copy to .env and fill in your values

# Database - Same Neon database as Context Vault
# Read-only access to CV tables, read-write for vault_graph schema
VAULT_GRAPH_DATABASE_URL=postgresql://user:password@host:5432/context_vault?sslmode=require

# OpenAI - Same key as Context Vault (for search embeddings)
VAULT_GRAPH_OPENAI_API_KEY=sk-...

# API Key - Same as Context Vault (for authentication)
VAULT_GRAPH_API_KEY=your-api-key

# R2 Storage - Same as Context Vault (for presigned URLs)
VAULT_GRAPH_S3_ENDPOINT_URL=https://xxx.r2.cloudflarestorage.com
VAULT_GRAPH_S3_ACCESS_KEY_ID=xxx
VAULT_GRAPH_S3_SECRET_ACCESS_KEY=xxx
VAULT_GRAPH_S3_BUCKET_NAME=context-vault

# Graph Settings (optional)
VAULT_GRAPH_EDGE_SIMILARITY_THRESHOLD=0.7
VAULT_GRAPH_EDGE_JACCARD_THRESHOLD=0.3
VAULT_GRAPH_MAX_KNN_EDGES=5

# Logging
VAULT_GRAPH_LOG_LEVEL=INFO
VAULT_GRAPH_ENVIRONMENT=development
